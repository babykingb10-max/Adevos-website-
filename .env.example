# ==================== SERVER ====================
PORT=5000
NODE_ENV=production
BASE_URL=http://localhost:5000
PUBLIC_SITE_URL=http://localhost:5000
FRONTEND_SUCCESS_REDIRECT=http://localhost:5000/index.html

# ==================== DATABASE (MongoDB Atlas) ====================
