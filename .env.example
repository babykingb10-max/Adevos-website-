# ==================== AUTH / JWT ====================
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change_this_too

# ==================== ADMIN LOGIN (username/password fallback) ====================
